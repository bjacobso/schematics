{
  "name": "@schematics/deploy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./dist/node.js",
      "default": "./src/node.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@schematics/alchemy": "workspace:*",
    "@schematics/artifacts": "workspace:*",
    "@schematics/core": "workspace:*",
    "@schematics/git-artifacts": "workspace:*",
    "@schematics/protocol": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
