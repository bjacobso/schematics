{
  "name": "schema-ide-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@schema-ide/server --filter=schema-ide-playground",
    "dev:server": "turbo run dev --filter=@schema-ide/server",
    "dev:playground": "turbo run dev --filter=schema-ide-playground",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "cloudflare:cleanup": "node scripts/cleanup-cloudflare-previews.mjs",
    "playground:build": "pnpm --dir apps/playground build",
    "playground:e2e": "pnpm --dir apps/playground test:e2e",
    "playground:e2e:update": "pnpm --dir apps/playground test:e2e:update",
    "playground:deploy": "pnpm alchemy deploy --stage prod",
    "playground:deploy:dry-run": "pnpm alchemy deploy --stage prod --dry-run",
    "serve": "pnpm run build && pnpm run playground:build && SCHEMA_IDE_STATIC_DIR=../../apps/playground/dist pnpm --dir packages/server start",
    "serve:smoke": "node scripts/smoke-serve.mjs",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "alchemy": "2.0.0-beta.40",
    "effect": "catalog:",
    "oxfmt": "0.44.0",
    "turbo": "2.8.20",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.1.3"
}
