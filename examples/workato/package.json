{
  "name": "@schematics/example-workato",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "workato-config": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./dist/cli.js",
      "default": "./src/cli.ts"
    },
    "./workspace-config": {
      "types": "./src/workspace-config.ts",
      "import": "./dist/workspace-config.js",
      "default": "./src/workspace-config.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@schematics/algebra": "workspace:*",
    "@schematics/artifacts": "workspace:*",
    "@schematics/cli": "workspace:*",
    "@schematics/core": "workspace:*",
    "@schematics/protocol": "workspace:*",
    "@schematics/provider": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
