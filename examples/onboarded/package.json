{
  "name": "@schematics/onboarded-config",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "onboarded-config": "./dist/cli.js",
    "onboarded-deploy": "./dist/deploy-cli-bin.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./dist/cli.js",
      "default": "./src/cli.ts"
    },
    "./workspace-config": {
      "types": "./src/workspace-config.ts",
      "import": "./dist/workspace-config.js",
      "default": "./src/workspace-config.ts"
    },
    "./deploy": {
      "types": "./src/deploy-cli.ts",
      "import": "./dist/deploy-cli.js",
      "default": "./src/deploy-cli.ts"
    },
    "./domain": {
      "types": "./src/domain/index.ts",
      "import": "./dist/domain/index.js",
      "default": "./src/domain/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:bundle": "schematics-build-binary --project ./src/workspace-config.ts --project-export OnboardedConfigProject --name onboarded-config --bundle-only",
    "build:sea": "schematics-build-binary --project ./src/workspace-config.ts --project-export OnboardedConfigProject --name onboarded-config",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@mui/material": "catalog:",
    "@schematics/alchemy": "workspace:*",
    "@schematics/algebra": "workspace:*",
    "@schematics/artifacts": "workspace:*",
    "@schematics/cli": "workspace:*",
    "@schematics/core": "workspace:*",
    "@schematics/example-ui": "workspace:*",
    "@schematics/git-artifacts": "workspace:*",
    "@schematics/protocol": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "0.27.7",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
